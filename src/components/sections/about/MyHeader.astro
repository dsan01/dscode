---
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import { Image } from 'astro:assets'
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
import fetchApi from '@lib/strapi'
import type { AboutMePageType } from '@data/data'
import Prose from '@primitives/Prose.astro'
import { marked } from 'marked'

let page: AboutMePageType | null = null
try {
  page = await fetchApi<AboutMePageType>({
    endpoint: 'about-me',
    // query: {
    //   populate: 'thumbnail',
    // },
    wrappedByKey: 'data',
    lang: lang,
  })
} catch (error) {
  console.log(error)
}

const htmlContent = marked.parse(page?.description ?? '')
---

<section class='font-body container py-6'>
  <div class='flex flex-col gap-4 lg:flex-row'>
    <div class='group relative basis-1/3'>
      <Image
        src={'/img/bg/BG_T3.png'}
        alt={''}
        aria-hidden='true'
        class='clipped-element h-auto w-full opacity-0'
        height='200'
        width='400'
      />
      <Image
        src={'/img/bg/BG_T3.png'}
        alt={'Fondo por defecto'}
        class='clipped-element absolute inset-0 h-full w-full object-cover opacity-100 transition-opacity duration-300 group-hover:opacity-0'
        height='200'
        width='400'
        loading={'eager'}
      />
      <Image
        src={'/img/bg/BG_T4.png'}
        alt={'Fondo al hacer hover'}
        class='clipped-element absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-300 group-hover:opacity-100'
        height='200'
        width='400'
        loading={'eager'}
      />
    </div>
    <div class='flex basis-2/3 flex-col'>
      <div set:html={t('about.intro.start')} />
      <h1
        class='font-title from-primary-700 via-primary-500 to-primary-300 bg-gradient-to-r bg-clip-text pb-1 text-4xl font-medium text-transparent xl:text-5xl'
      >
        {page?.page_title ?? t('hero.title')}
      </h1>
      <Prose>
        <div set:html={htmlContent} />
      </Prose>
    </div>
  </div>
</section>

<svg
  width='0'
  height='0'
>
  <defs>
    <clipPath
      id='myArchClip'
      clipPathUnits='objectBoundingBox'
    >
      <path
        d='M0.5,1 C0.224,1,0,0.851,0,0.667 L0,0 L1,0 L1,0.667 C1,0.851,0.776,1,0.5,1 Z'
      ></path>
    </clipPath>
  </defs>
</svg>

<style>
  .clipped-element {
    clip-path: url(#myArchClip);
    -webkit-clip-path: url(#myArchClip);
    width: 100%;
    max-width: 300px;
    height: 400px;
    margin: auto;
    border-radius: 16px;
  }
</style>
